# 🌊 N84 Employment Platform - Environment Variables Example

# --- Supabase Configuration ---
# get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (keep this secret!)
DATABASE_URL=postgresql://postgres.xxx:password@host:port/postgres

# --- AI Configuration (Dashscope / Alibaba Cloud) ---
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-32b (or other supported model)

# --- Telegram Configuration ---
TELEGRAM_BOT_TOKEN=123456789:ABCDE-YourBotToken
TELEGRAM_BOT_USERNAME=YourBot_bot

# --- Application Settings ---
NEXT_PUBLIC_SITE_URL=https://n84-platform.vercel.app
